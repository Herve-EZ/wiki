{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WikiCollab",
  "version": "0.7.0",
  "identifier": "com.ezaudiovisuel.wikicollab",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "WikiCollab",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["wikicollab"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMjI2MEM4M0I4RkM0RUEKUldUcXhJODd5R0FpMjFRTTJxSTg2YjRKZXZaZVh0eThTZjh4TjJ3Y2lwRTFlMC8wTDgyQXhxcjAK",
      "endpoints": [
        "https://github.com/Herve-EZ/Wiki/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
