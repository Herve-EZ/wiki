# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=wikicollab
POSTGRES_USER=wikicollab
POSTGRES_PASSWORD=wikicollab
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Secrets MFA — clé dédiée au chiffrement des secrets TOTP au repos.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
# (fallback : SECRET_KEY ; la changer invalide les TOTP enrôlés)
MFA_ENCRYPTION_KEY=

# CORS — origines du frontend (SPA Vite en dev). En DEBUG, tout localhost:<port>
# et l'app Tauri sont acceptés automatiquement (voir settings.py).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Tests locaux sans services : DJANGO_DB=sqlite DJANGO_CACHE=locmem DJANGO_CHANNEL_LAYER=inmemory
# (défauts appliqués automatiquement par pytest via conftest.py)

# Photo de profil — bucket S3 (Contabo Object Storage). SEULES les photos de
# profil utilisent S3 ; le reste des fichiers reste sur le disque local.
# Laisser AVATAR_S3_BUCKET vide pour retomber sur le stockage local (dev/tests).
AVATAR_S3_ENDPOINT_URL=https://eu2.contabostorage.com
AVATAR_S3_BUCKET=
AVATAR_S3_ACCESS_KEY=
AVATAR_S3_SECRET_KEY=
# Contabo ignore généralement la région : laisser vide sauf besoin explicite.
AVATAR_S3_REGION=
# Hôte public servant les objets (sans schéma). REQUIS sur Contabo : l'accès
# anonyme passe par un chemin préfixé par l'ID de tenant, sinon 401. Format :
#   <region>.contabostorage.com/<TENANT_ID>:<BUCKET>
# ex. eu2.contabostorage.com/c861cafd5ebc4e7497b224b8e946c1c1:wiki-collab
# (le TENANT_ID est visible dans l'URL du bucket fournie par Contabo).
AVATAR_S3_CUSTOM_DOMAIN=
# ACL des objets uploadés (avatars publics → URL directement utilisable).
AVATAR_S3_ACL=public-read

# SSO providers (configure real values via admin > Social applications,
# or inject here and load in settings). Leave blank to disable a provider.
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_SECRET=
